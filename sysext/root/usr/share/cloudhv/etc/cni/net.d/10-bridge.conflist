{
  "cniVersion": "1.0.0",
  "name": "bridge",
  "plugins": [
    {
      "type": "bridge",
      "bridge": "cni0",
      "isGateway": true,
      "ipMasq": true,
      "ipam": { "type": "host-local", "ranges": [[{"subnet": "10.88.0.0/16"}]] }
    },
    { "type": "portmap", "capabilities": {"portMappings": true} },
    { "type": "loopback" }
  ]
}
