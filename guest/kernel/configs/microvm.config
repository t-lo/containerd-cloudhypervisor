#
# Minimal kernel config for Cloud Hypervisor microVMs
#
# Based on ch_defconfig with additions for container workloads.
# Target: < 5MB vmlinux, < 100ms boot time.
#
# This is a partial config — use with `make olddefconfig` to fill defaults.
#

# --- Architecture ---
CONFIG_64BIT=y
CONFIG_SMP=y

# Required to strip standard kernel features like VT, VGA_CONSOLE
CONFIG_EXPERT=y
# --- No legacy hardware ---
CONFIG_ACPI=y
CONFIG_PCI=y
CONFIG_PCIEPORTBUS=y
CONFIG_PCI_MSI=y
CONFIG_VGA_CONSOLE=n
CONFIG_FRAMEBUFFER_CONSOLE=n
CONFIG_DRM=n
CONFIG_SOUND=n
CONFIG_USB=n
CONFIG_HID=n

# --- Virtio (Cloud Hypervisor transport) ---
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS_COMMON=y
CONFIG_VHOST_VSOCK=n
CONFIG_VIRTIO_MEM=y

# --- Filesystems ---
CONFIG_EROFS_FS=y
CONFIG_EROFS_FS_XATTR=y
CONFIG_EROFS_FS_POSIX_ACL=y
CONFIG_EROFS_FS_SECURITY=y
CONFIG_EXT4_FS=y
CONFIG_OVERLAY_FS=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# --- Block layer ---
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y

# Required for IPC_NS
CONFIG_POSIX_MQUEUE=y
# --- Namespaces (container isolation) ---
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y

# --- Cgroups v2 (container resource limits) ---
CONFIG_CGROUPS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_PERF=n
CONFIG_CGROUP_BPF=y
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP=y
CONFIG_CGROUP_SCHED=y
CONFIG_FAIR_GROUP_SCHED=y
CONFIG_CFS_BANDWIDTH=y

# --- Networking (minimal — container networking) ---
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_NETFILTER=y
CONFIG_BRIDGE=y
CONFIG_VETH=y
CONFIG_TUN=n
CONFIG_PACKET=y
CONFIG_UNIX=y

# --- Security ---
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_SECURITY=n
CONFIG_SELINUX=n
CONFIG_APPARMOR=n

# --- Memory management ---
CONFIG_TRANSPARENT_HUGEPAGE=n
CONFIG_MEMORY_HOTPLUG=y
CONFIG_MHP_DEFAULT_ONLINE_TYPE_ONLINE_AUTO=y
CONFIG_MEMORY_HOTREMOVE=y
CONFIG_COMPACTION=y

# --- Disable unnecessary features ---
CONFIG_MODULES=n
CONFIG_SWAP=n
CONFIG_DEBUG_INFO=n
CONFIG_FTRACE=n
CONFIG_PRINTK=y
CONFIG_BUG=y
CONFIG_KALLSYMS=n
CONFIG_PROFILING=n
CONFIG_KPROBES=n
CONFIG_WIRELESS=n
CONFIG_WLAN=n
CONFIG_BLUETOOTH=n
CONFIG_NFS_FS=n
CONFIG_CRYPTO=y
CONFIG_CRYPTO_HW=n

# --- Fast boot ---
CONFIG_PRINTK_TIME=n
CONFIG_BOOT_PRINTK_DELAY=n
CONFIG_DETECT_HUNG_TASK=n
CONFIG_SCHED_DEBUG=n

# --- RNG for containers ---
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y

# BPF support (required by runc for cgroup v2 device control)
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y

# ACPI PCI hot-plug (required for vm.add-disk at runtime)
CONFIG_HOTPLUG_PCI=y
CONFIG_HOTPLUG_PCI_ACPI=y
CONFIG_ACPI_HOTPLUG_MEMORY=y

# Kernel-level IP autoconfiguration (required for ip= boot parameter)

# Network device drivers (required for virtio-net to work)
CONFIG_NETDEVICES=y
CONFIG_NET_CORE=y
CONFIG_ETHERNET=y

# Kernel-level IP autoconfiguration (ip= boot parameter)
CONFIG_IP_PNP=y
CONFIG_PSI=y
CONFIG_PSI_DEFAULT_DISABLED=n
CONFIG_VIRTIO_BALLOON=y
CONFIG_PAGE_REPORTING=y
